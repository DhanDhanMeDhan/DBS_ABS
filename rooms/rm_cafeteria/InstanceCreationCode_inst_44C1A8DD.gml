				[scr_cutscene_variable,variable.normal,o_bunbun,"direction",0],
				[scr_cutscene_variable,variable.normal,o_todd,"direction",180],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Ah, o Tio Big B só serve para contar histórias"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["Ele é quem cuida da horta no quintal e do jardim dele... Que é da onde vem os temperos..."]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Ele, ele só serve para contar histórias e para isso"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["Ele também é o primeiro a levantar para cuidar dos bebês"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["E isso..."]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["O Tio Big B também é responsável pela manutenção pesada de algumas coisas da casa... Lembra quando o gerador quebrou no ano passado?"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Tá... E isso também..."]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["Ah! Eu esqueci daquela vez que-"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Eu já entendi, BunBun!"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["HeeHee, desculpe... Mas sim, as histórias do Tio Big B são boas!"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["Tanto as dele quanto as do Fritz!"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Ah! Sim!! Qual será a história que ele vai contar hoje a noite?"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["A última foi legal mas eu não entendi muito..."]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["O Fritz tem dessas, ele gosta de histórias não convencionais"]],
				[scr_cutscene_wait,.5],
