				[scr_cutscene_variable,variable.normal,o_todd,"direction",270],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["BunBun, Todd"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["Ah! Olá, Hellen! No que podemos ajudar?"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Oi, Hellen"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["Ah, é que... Eu ouvi vocês falando sobre o Fritz..."]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Sim sim, ele é incrivel"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Inteligente e sempre criativo, me dá um pouco de medo pelo modo de agir"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Mas ainda assim o admiro muito"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["Uh-Hum!! Ele sempre conhece uma história! E nsempre são boas histórias!!"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["Oh, então vocês são bastente amigos dele?"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Eu diria que mais o BunBun do que eu"]],
				[scr_cutscene_variable,variable.normal,o_bunbun,"direction",0],
				[scr_cutscene_variable,variable.normal,o_todd,"direction",180],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["Uh? Como assim?"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Sim, você sempre está perguntando para as pessoas como elas estão, se precisam de ajuda e tudo mais"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Não me surpreenderia se ele te considerasse você fosse mais amigo dele do que eu"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Ele fala comigo por que sou sua dupla, isso eu tenho certeza"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["Oh... Se você diz..."]],
				[scr_cutscene_variable,variable.normal,o_bunbun,"direction",270],
				[scr_cutscene_variable,variable.normal,o_todd,"direction",270],
				[scr_cutscene_variable,variable.normal,o_hellen,"direction",135],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["Então você, conhece mais o Fritz, posso dizer?"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["Posso dizer que sim"]],
				[scr_cutscene_wait,.5],
				[scr_cutscene_variable,variable.normal,o_hellen,"direction",180],
				[scr_cutscene_wait,.1],
				[scr_cutscene_variable,variable.normal,o_hellen,"direction",225],
