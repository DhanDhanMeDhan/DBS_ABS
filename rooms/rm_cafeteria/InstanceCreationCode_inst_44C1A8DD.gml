				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["Todd!!"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["O que?! Eu sou gente, não vou trabalhar de graça"]],
				[scr_cutscene_variable,variable.normal,o_bunbun,"direction",270],
				[scr_cutscene_variable,variable.normal,o_todd,"direction",270],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["A gente vai te ajudar, Hellen"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["HaaHaa! Muito obrigada!! De verdade!"]],
				[scr_cutscene_variable,variable.normal,o_hellen,"direction",135],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["Bom, podemos ir para meu quarto? Falar aqui é meio... Vergonhoso..."]],
				[scr_cutscene_variable,variable.normal,o_hellen,"direction",45],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Sem problemas, vamos nessa!"]],
