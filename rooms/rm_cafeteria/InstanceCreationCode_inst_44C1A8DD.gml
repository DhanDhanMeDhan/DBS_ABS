				[scr_cutscene_talk_animated,cutscene_talk_mode.normal,o_todd,["Soufflé de cenoura!!..."],-1,[[0],[s_todd_casual_spices_idle],[s_todd_casual_spices_talk]],false,false,[0,.2,.25]],
				[scr_cutscene_talk_animated,cutscene_talk_mode.normal,o_todd,["E suco de abacaxi com hortelã!!..."],-1,[[0],[s_todd_casual_spices_idle],[s_todd_casual_spices_talk]],false,false,[0,.2,.25]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["Mas eu pensei que você nem gostava de soufflé de cenoura..."]],
				[scr_cutscene_talk_animated,cutscene_talk_mode.normal,o_todd,["Sendo dela, eu gosto!"],-1,[[0],[s_todd_casual_spices_idle],[s_todd_casual_spices_talk]],false,false,[0,.2,.25]],
