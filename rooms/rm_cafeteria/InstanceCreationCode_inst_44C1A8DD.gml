				[scr_cutscene_variable,variable.normal,o_hellen,"direction",135],
				[scr_cutscene_wait,.1],
				[scr_cutscene_variable,variable.normal,o_hellen,"direction",90],
				[scr_cutscene_wait,.5],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["BunBun, Todd, eu preciso da ajuda de vocês... É sobre o Fritz.."]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Hum... Do que precisa?"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["É um segredo, mas não é nada atroz"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["É o que?"]],
				[scr_cutscene_variable,variable.normal,o_bunbun,"direction",0],
				[scr_cutscene_variable,variable.normal,o_todd,"direction",180],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_bunbun,["É segredo, mas não nada ruim"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Por que ela fica inventando palavra?"]],
				[scr_cutscene_variable,variable.normal,o_bunbun,"direction",270],
				[scr_cutscene_variable,variable.normal,o_todd,"direction",270],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["Eu não to inventando palavra... Atroz é uma palavra que existe!"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["Eu acho mais é que você e o BunBun tem um dialeto secreto"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["Mas-"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["Ok. Tudo bem-"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_hellen,["Bom, ainda assim, podem me ajudar?"]],
				[scr_cutscene_talk,cutscene_talk_mode.normal,o_todd,["O que a gente ganha?"]],
